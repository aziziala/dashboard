{
  "name": "sms-taxi-admin",
  "version": "1.0.0",
  "description": "Admin Dashboard for SMS Taxi Application",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4100",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "nginx:setup": "sudo bash setup-nginx.sh",
    "nginx:install": "sudo bash install-and-setup-nginx.sh",
    "nginx:fix": "sudo bash fix-nginx-install.sh",
    "nginx:minimal-fix": "sudo bash nginx-minimal-fix.sh",
    "nginx:test": "sudo nginx -t",
    "nginx:reload": "sudo systemctl reload nginx",
    "nginx:restart": "sudo systemctl restart nginx",
    "nginx:status": "sudo systemctl status nginx",
    "nginx:stop": "sudo systemctl stop nginx",
    "nginx:start": "sudo systemctl start nginx",
    "nginx:logs": "sudo tail -f /var/log/nginx/error.log"
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/cdk": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/localize": "^17.3.0",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@coreui/icons": "^3.0.1",
    "@mdi/font": "^7.4.47",
    "@ng-bootstrap/ng-bootstrap": "^16.0.0",
    "@popperjs/core": "^2.11.8",
    "@stomp/stompjs": "^7.2.1",
    "@types/leaflet": "^1.9.8",
    "apexcharts": "^3.44.0",
    "bootstrap": "^5.3.8",
    "boxicons": "^2.1.4",
    "chart.js": "^4.4.0",
    "date-fns": "^2.30.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "moment": "^2.29.4",
    "ng-apexcharts": "^2.0.1",
    "ng2-charts": "^5.0.4",
    "rxjs": "~7.8.1",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.6.2",
    "xlsx": "^0.18.5",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  }
}
