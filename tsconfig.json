{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./out-tsc",
    "sourceMap": true,
    "declaration": false,

    "experimentalDecorators": true,
    "importHelpers": true,

    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",

    "useDefineForClassFields": false,

    "lib": [
      "ES2022",
      "dom"
    ]
  }
}